   "source": [
    "# 🌿 植被检测模型下载脚本\n",
    "### 自动下载6个模型（代码+权重）到 Google Drive\n",
    "\n",
    "| # | 模型 | 年份 |\n",
    "|---|------|------|\n",
    "| 1 | RSPrompter | 2024 |\n",
    "| 2 | EfficientSAM | 2024 |\n",
    "| 3 | SegNeXt | 2024 |\n",
    "| 4 | UniSAM | 2025 |\n",
    "| 5 | YOLO11-seg | 2025 |\n",
    "| 6 | SegEarth-OV | 2025 |"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 1: 挂载 Google Drive\n",
    "# ==============================\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "import os\n",
    "\n",
    "# 根目录（可修改为你想要的路径）\n",
    "BASE_DIR = '/content/drive/MyDrive/vegetation_models'\n",
    "os.makedirs(BASE_DIR, exist_ok=True)\n",
    "print(f'✅ 根目录创建成功: {BASE_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 2: 安装依赖\n",
    "# ==============================\n",
    "!pip install -q huggingface_hub gdown\n",
    "print('✅ 依赖安装完成')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 3: 下载 RSPrompter (2024)\n",
    "# 遥感专用SAM提示学习，最契合紫金山数据集\n",
    "# ==============================\n",
    "import subprocess\n",
    "\n",
    "MODEL_DIR = os.path.join(BASE_DIR, '1_RSPrompter')\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "\n",
    "print('📦 正在clone RSPrompter代码...')\n",
    "subprocess.run([\n",
    "    'git', 'clone',\n",
    "    'https://github.com/KyanChen/RSPrompter.git',\n",
    "    os.path.join(MODEL_DIR, 'code')\n",
    "], check=True)\n",
    "\n",
    "print('⬇️  正在下载RSPrompter权重...')\n",
    "# 权重来自HuggingFace\n",
    "from huggingface_hub import hf_hub_download\n",
    "weight_path = hf_hub_download(\n",
    "    repo_id='KyanChen/RSPrompter',\n",
    "    filename='rsprompter_anchor-20230823.pth',\n",
    "    local_dir=os.path.join(MODEL_DIR, 'weights')\n",
    ")\n",
    "print(f'✅ RSPrompter 完成！权重保存至: {weight_path}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 4: 下载 EfficientSAM (2024)\n",
    "# 轻量SAM蒸馏版，权重仅~100MB\n",
    "# ==============================\n",
    "MODEL_DIR = os.path.join(BASE_DIR, '2_EfficientSAM')\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "\n",
    "print('📦 正在clone EfficientSAM代码...')\n",
    "subprocess.run([\n",
    "    'git', 'clone',\n",
    "    'https://github.com/yformer/EfficientSAM.git',\n",
    "    os.path.join(MODEL_DIR, 'code')\n",
    "], check=True)\n",
    "\n",
    "print('⬇️  正在下载EfficientSAM权重 (tiny版 ~10MB)...')\n",
    "import urllib.request\n",
    "weights_dir = os.path.join(MODEL_DIR, 'weights')\n",
    "os.makedirs(weights_dir, exist_ok=True)\n",
    "\n",
    "# EfficientSAM-Ti (tiny, 最轻量)\n",
    "urllib.request.urlretrieve(\n",
    "    'https://huggingface.co/spaces/yunyangx/EfficientSAM/resolve/main/efficient_sam_vitt.pt',\n",
    "    os.path.join(weights_dir, 'efficient_sam_vitt.pt')\n",
    ")\n",
    "# EfficientSAM-S (small)\n",
    "urllib.request.urlretrieve(\n",
    "    'https://huggingface.co/spaces/yunyangx/EfficientSAM/resolve/main/efficient_sam_vits.pt',\n",
    "    os.path.join(weights_dir, 'efficient_sam_vits.pt')\n",
    ")\n",
    "print(f'✅ EfficientSAM 完成！保存至: {MODEL_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 5: 下载 SegNeXt (2024)\n",
    "# 轻量Transformer分割，权重仅~30MB\n",
    "# ==============================\n",
    "MODEL_DIR = os.path.join(BASE_DIR, '3_SegNeXt')\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "\n",
    "print('📦 正在clone SegNeXt代码...')\n",
    "subprocess.run([\n",
    "    'git', 'clone',\n",
    "    'https://github.com/Visual-Attention-Network/SegNeXt.git',\n",
    "    os.path.join(MODEL_DIR, 'code')\n",
    "], check=True)\n",
    "\n",
    "print('⬇️  正在下载SegNeXt-Small权重 (~30MB)...')\n",
    "weights_dir = os.path.join(MODEL_DIR, 'weights')\n",
    "os.makedirs(weights_dir, exist_ok=True)\n",
    "\n",
    "# SegNeXt-S backbone (MSCAN-Small)\n",
    "urllib.request.urlretrieve(\n",
    "    'https://download.openmmlab.com/mmsegmentation/v0.5/segnext/segnext_mscan-s_1x1_512x512_160k_ade20k/segnext_mscan-s_1x1_512x512_160k_ade20k_20230227_023054-7a8ff228.pth',\n",
    "    os.path.join(weights_dir, 'segnext_small_ade20k.pth')\n",
    ")\n",
    "print(f'✅ SegNeXt 完成！保存至: {MODEL_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 6: 下载 YOLO11-seg (2025)\n",
    "# 检测+分割一体，契合\"分割检测\"方向\n",
    "# ==============================\n",
    "MODEL_DIR = os.path.join(BASE_DIR, '4_YOLO11seg')\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "\n",
    "print('📦 安装 ultralytics (包含YOLO11)...')\n",
    "subprocess.run(['pip', 'install', '-q', 'ultralytics'], check=True)\n",
    "\n",
    "print('⬇️  正在下载YOLO11-seg权重...')\n",
    "weights_dir = os.path.join(MODEL_DIR, 'weights')\n",
    "os.makedirs(weights_dir, exist_ok=True)\n",
    "\n",
    "# YOLO11n-seg (nano, 最小) ~6MB\n",
    "urllib.request.urlretrieve(\n",
    "    'https://github.com/ultralytics/assets/releases/download/v8.3.0/yolo11n-seg.pt',\n",
    "    os.path.join(weights_dir, 'yolo11n-seg.pt')\n",
    ")\n",
    "# YOLO11s-seg (small) ~22MB\n",
    "urllib.request.urlretrieve(\n",
    "    'https://github.com/ultralytics/assets/releases/download/v8.3.0/yolo11s-seg.pt',\n",
    "    os.path.join(weights_dir, 'yolo11s-seg.pt')\n",
    ")\n",
    "print(f'✅ YOLO11-seg 完成！保存至: {MODEL_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 7: 下载 SegEarth-OV (2025)\n",
    "# 25年遥感开放词汇分割，专为遥感场景设计\n",
    "# ==============================\n",
    "MODEL_DIR = os.path.join(BASE_DIR, '5_SegEarth_OV')\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "\n",
    "print('📦 正在clone SegEarth-OV代码...')\n",
    "subprocess.run([\n",
    "    'git', 'clone',\n",
    "    'https://github.com/likyoo/SegEarth-OV.git',\n",
    "    os.path.join(MODEL_DIR, 'code')\n",
    "], check=True)\n",
    "\n",
    "print('⬇️  正在从HuggingFace下载SegEarth-OV权重...')\n",
    "weights_dir = os.path.join(MODEL_DIR, 'weights')\n",
    "os.makedirs(weights_dir, exist_ok=True)\n",
    "\n",
    "# 使用huggingface_hub下载\n",
    "try:\n",
    "    from huggingface_hub import snapshot_download\n",
    "    snapshot_download(\n",
    "        repo_id='likyoo/SegEarth-OV',\n",
    "        local_dir=weights_dir,\n",
    "        ignore_patterns=['*.git*']\n",
    "    )\n",
    "    print(f'✅ SegEarth-OV 完成！保存至: {MODEL_DIR}')\n",
    "except Exception as e:\n",
    "    print(f'⚠️ HuggingFace下载失败，请手动下载: https://huggingface.co/likyoo/SegEarth-OV')\n",
    "    print(f'错误信息: {e}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 8: 下载 UniSAM (2025)\n",
    "# 统一SAM框架，最新SAM改进版\n",
    "# ==============================\n",
    "MODEL_DIR = os.path.join(BASE_DIR, '6_UniSAM')\n",
    "os.makedirs(MODEL_DIR, exist_ok=True)\n",
    "\n",
    "print('📦 正在clone UniSAM代码...')\n",
    "subprocess.run([\n",
    "    'git', 'clone',\n",
    "    'https://github.com/ziplab/UniSAM.git',\n",
    "    os.path.join(MODEL_DIR, 'code')\n",
    "], check=True)\n",
    "\n",
    "print('⬇️  正在下载UniSAM权重...')\n",
    "weights_dir = os.path.join(MODEL_DIR, 'weights')\n",
    "os.makedirs(weights_dir, exist_ok=True)\n",
    "\n",
    "try:\n",
    "    from huggingface_hub import snapshot_download\n",
    "    snapshot_download(\n",
    "        repo_id='ziplab/UniSAM',\n",
    "        local_dir=weights_dir,\n",
    "        ignore_patterns=['*.git*']\n",
    "    )\n",
    "    print(f'✅ UniSAM 完成！保存至: {MODEL_DIR}')\n",
    "except Exception as e:\n",
    "    print(f'⚠️ 下载失败，请手动下载: https://huggingface.co/ziplab/UniSAM')\n",
    "    print(f'错误信息: {e}')"
   ],
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# ==============================\n",
    "# Step 9: 汇总检查所有下载结果\n",
    "# ==============================\n",
    "import os\n",
    "\n",
    "print('=' * 50)\n",
    "print('📊 下载结果汇总')\n",
    "print('=' * 50)\n",
    "\n",
    "models = [\n",
    "    ('1_RSPrompter',   '2024', 'RSPrompter'),\n",
    "    ('2_EfficientSAM', '2024', 'EfficientSAM'),\n",
    "    ('3_SegNeXt',      '2024', 'SegNeXt'),\n",
    "    ('4_YOLO11seg',    '2025', 'YOLO11-seg'),\n",
    "    ('5_SegEarth_OV',  '2025', 'SegEarth-OV'),\n",
    "    ('6_UniSAM',       '2025', 'UniSAM'),\n",
    "]\n",
    "\n",
    "for folder, year, name in models:\n",
    "    path = os.path.join(BASE_DIR, folder)\n",
    "    code_ok = os.path.exists(os.path.join(path, 'code'))\n",
    "    weight_ok = os.path.exists(os.path.join(path, 'weights'))\n",
    "    \n",
    "    # 统计权重文件大小\n",
    "    total_size = 0\n",
    "    weight_dir = os.path.join(path, 'weights')\n",
    "    if os.path.exists(weight_dir):\n",
    "        for f in os.listdir(weight_dir):\n",
    "            fp = os.path.join(weight_dir, f)\n",
    "            if os.path.isfile(fp):\n",
    "                total_size += os.path.getsize(fp)\n",
    "    \n",
    "    size_mb = total_size / (1024 * 1024)\n",
    "    code_status = '✅' if code_ok else '❌'\n",
    "    weight_status = '✅' if weight_ok and size_mb > 0 else '❌'\n",
    "    \n",
    "    print(f'{code_status} 代码 {weight_status} 权重({size_mb:.1f}MB) | [{year}] {name}')\n",
    "\n",
    "print('=' * 50)\n",
    "print(f'📁 所有文件保存在: {BASE_DIR}')"
   ],
   "execution_count": null,
   "outputs": []
  }
 ]
}"
