ll be required to pass the indexing argument. (Triggered internally at /pytorch/aten/src/ATen/native/TensorShape.cpp:4381.)\n","  return _VF.meshgrid(tensors, **kwargs)  # type: ignore[attr-defined]\n"]},{"data":{"text/plain":["{'Model': 'SegEarth-OV',\n"," 'Params_M': 149.914,\n"," 'FLOPs_G': 211.451,\n"," 'Inference_Time_ms': 36.195,\n"," 'FPS': 27.63,\n"," 'GPU_Memory_MB': 3531.7,\n"," 'Input_Size': '448x448',\n"," 'Device': 'NVIDIA RTX PRO 6000 Blackwell Server Edition',\n"," 'Notes': 'CLIP ViT-B/16 + SimFeatUp JBU; forward_feature only; 2x THOP MACs; warmup=10, repeats=100, batch=1, FP16.'}"]},"execution_count":4,"metadata":{},"output_type":"execute_result"}],"source":["import os\n","import sys\n","import time\n","import gc\n","from pathlib import Path\n","\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","\n","PROJECT_ROOT = Path(\"/content/drive/MyDrive/vegetation_models_v2\")\n","SEG_ROOT = PROJECT_ROOT / \"4_SegEarth_OV\"\n","CODE_DIR = SEG_ROOT / \"code\"\n","\n","sys.path.insert(0, str(CODE_DIR))\n","\n","from open_clip import tokenizer, create_model\n","from prompts.imagenet_template import openai_imagenet_template\n","from simfeatup_dev.upsamplers import get_upsampler\n","\n","\n","class SegEarthForwardOnly(nn.Module):\n","    def __init__(self, device=\"cuda\"):\n","        super().__init__()\n","        self.device_name = device\n","        pretrained = \"openai\"\n","        print(\"CLIP pretrained source:\", pretrained)\n","\n","        self.net = create_model(\n","            \"ViT-B/16\",\n","            pretrained=pretrained,\n","            precision=\"fp16\",\n","        ).eval().to(device)\n","\n","        self.patch_size = self.net.visual.patch_size\n","        self.feat_dim = 512\n","        self.model_type = \"SegEarth\"\n","        self.ignore_residual = True\n","        self.output_cls_token = False\n","\n","        class_names = [\"background\", \"vegetation\"]\n","        query_features = []\n","        with torch.no_grad():\n","            for name in class_names:\n","                texts = [template(name) for template in openai_imagenet_template]\n","                query = tokenizer.tokenize(texts).to(device)\n","                feat = self.net.encode_text(query)\n","                feat = feat / feat.norm(dim=-1, keepdim=True)\n","                feat = feat.mean(dim=0)\n","                feat = feat / feat.norm()\n","                query_features.append(feat.unsqueeze(0))\n","\n","        self.register_buffer(\"query_features\", torch.cat(query_features, dim=0))\n","\n","        upsampler_ckpt = CODE_DIR / \"simfeatup_dev\" / \"weights\" / \"xclip_jbu_one_million_aid.ckpt\"\n","        assert upsampler_ckpt.exists(), f\"Missing SimFeatUp weight: {upsampler_ckpt}\"\n","\n","        self.upsampler = get_upsampler(\"jbu_one\", self.feat_dim).cuda().half()\n","        ckpt = torch.load(upsampler_ckpt, map_location=\"cpu\")[\"state_dict\"]\n","        weights_dict = {k[10:]: v for k, v in ckpt.items()}\n","        self.upsampler.load_state_dict(weights_dict, strict=True)\n","        self.upsampler.eval()\n","\n","    def forward(self, img):\n","        image_features = self.net.encode_image(\n","            img,\n","            self.model_type,\n","            self.ignore_residual,\n","            self.output_cls_token,\n","        )\n","\n","        feature_w = img.shape[-2] // self.patch_size[0]\n","        feature_h = img.shape[-1] // self.patch_size[1]\n","        image_w, image_h = img.shape[-2], img.shape[-1]\n","\n","        image_features = image_features.permute(0, 2, 1).view(\n","            1, self.feat_dim, feature_w, feature_h\n","        )\n","\n","        with torch.cuda.amp.autocast():\n","            image_features = self.upsampler(image_features, img).half()\n","\n","        image_features = image_features.view(\n","            1, self.feat_dim, image_w * image_h\n","        ).permute(0, 2, 1)\n","\n","        image_features = image_features / image_features.norm(dim=-1, keepdim=True)\n","        logits = image_features @ self.query_features.T\n","        logits = logits.permute(0, 2, 1).reshape(1, 2, image_w, image_h)\n","        return logits\n","\n","\n","def measure(model, size=448, warmup=10, repeats=100):\n","    device = torch.device(\"cuda\")\n","    sample = torch.randn(1, 3, size, size, device=device, dtype=torch.float16)\n","\n","    params_m = sum(p.numel() for p in model.parameters()) / 1e6\n","\n","    with torch.inference_mode():\n","        for _ in range(warmup):\n","            _ = model(sample)\n","        torch.cuda.synchronize()\n","        torch.cuda.reset_peak_memory_stats()\n","\n","        start = time.perf_counter()\n","        for _ in range(repeats):\n","            _ = model(sample)\n","        torch.cuda.synchronize()\n","\n","    ms = (time.perf_counter() - start) * 1000 / repeats\n","    fps = 1000 / ms\n","    mem_mb = torch.cuda.max_memory_allocated() / 1024 / 1024\n","\n","    flops_g = \"N/A\"\n","    flops_note = \"N/A\"\n","    try:\n","        from thop import profile\n","        macs, _ = profile(model, inputs=(sample,), verbose=False)\n","        flops_g = 2.0 * macs / 1e9\n","        flops_note = \"2x THOP MACs\"\n","    except Exception as e:\n","        try:\n","            with torch.profiler.profile(with_flops=True) as prof:\n","                with torch.inference_mode():\n","                    _ = model(sample)\n","            flops = sum(evt.flops for evt in prof.key_averages() if evt.flops)\n","            flops_g = flops / 1e9 if flops > 0 else \"N/A\"\n","            flops_note = f\"PyTorch profiler fallback; THOP failed: {type(e).__name__}\"\n","        except Exception as e2:\n","            flops_note = f\"FLOPs unavailable: THOP={type(e).__name__}, profiler={type(e2).__name__}\"\n","\n","    return {\n","        \"Model\": \"SegEarth-OV\",\n","        \"Params_M\": round(params_m, 3),\n","        \"FLOPs_G\": round(flops_g, 3) if isinstance(flops_g, float) else flops_g,\n","        \"Inference_Time_ms\": round(ms, 3),\n","        \"FPS\": round(fps, 2),\n","        \"GPU_Memory_MB\": round(mem_mb, 1),\n","        \"Input_Size\": f\"{size}x{size}\",\n","        \"Device\": torch.cuda.get_device_name(0),\n","        \"Notes\": f\"CLIP ViT-B/16 + SimFeatUp JBU; forward_feature only; {flops_note}; warmup={warmup}, repeats={repeats}, batch=1, FP16.\",\n","    }\n","\n","\n","gc.collect()\n","torch.cuda.empty_cache()\n","\n","model = SegEarthForwardOnly(device=\"cuda\").eval()\n","result = measure(model, size=448, warmup=10, repeats=100)\n","result"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":37,"status":"ok","timestamp":1783733947704,"user":{"displayName":"demo demo","userId":"05008526215588824690"},"user_tz":-480},"id":"_zL-TrRT23ZJ","outputId":"092c830e-220e-47ca-bcbc-7b6b084f4f5f"},"outputs":[{"name":"stdout","output_type":"stream","text":["ROOT = /content/vegetation_foundation_models\n","HF_HOME = /content/vegetation_foundation_models/_cache/hf_cache\n","TORCH_HOME = /content/vegetation_foundation_models/_cache/torch_cache\n"]}],"source":["# 涓嬭浇妯″瀷鍜屾潈閲峔n","# =========================\n","# 0. Paths\n","# =========================\n","import os\n","from pathlib import Path\n","\n","ROOT = Path('/content/vegetation_foundation_models')\n","CACHE = ROOT / '_cache'\n","\n","ROOT.mkdir(parents=True, exist_ok=True)\n","CACHE.mkdir(parents=True, exist_ok=True)\n","\n","os.environ['HF_HOME'] = str(CACHE / 'hf_cache')\n","os.environ['HUGGINGFACE_HUB_CACHE'] = str(CACHE / 'hf_cache' / 'hub')\n","os.environ['TORCH_HOME'] = str(CACHE / 'torch_cache')\n","\n","print('ROOT =', ROOT)\n","print('HF_HOME =', os.environ['HF_HOME'])\n","print('TORCH_HOME =', os.environ['TORCH_HOME'])"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":22235,"status":"ok","timestamp":