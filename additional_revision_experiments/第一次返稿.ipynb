,"source":["%%bash\n","cd /content/vegetation_models_v2\n","\n","python - <<'PY'\n","import pandas as pd\n","from pathlib import Path\n","\n","path = Path(\"results/four_model_robustness_colab.csv\")\n","df = pd.read_csv(path)\n","\n","# 纭繚鏍稿績鍒楀瓨鍦╘n","for col in [\"mIoU\", \"F1\", \"Accuracy\", \"Delta_mIoU\", \"Delta_F1\", \"Delta_Accuracy\"]:\n","    if col not in df.columns:\n","        df[col] = pd.NA\n","\n","# Qwen / box-mask 琛岋細鎶?box-mask 鎸囨爣鏄犲皠鍒扮粺涓€鍒梊n","is_qwen = df[\"model\"].astype(str).str.contains(\"Qwen|Qwen2.5\", case=False, na=False)\n","is_box = df.get(\"metric_type\", \"\").astype(str).str.contains(\"box-mask\", case=False, na=False)\n","mask = is_qwen | is_box\n","\n","if \"box_mask_iou\" in df.columns:\n","    df.loc[mask, \"mIoU\"] = df.loc[mask, \"box_mask_iou\"]\n","if \"box_mask_f1\" in df.columns:\n","    df.loc[mask, \"F1\"] = df.loc[mask, \"box_mask_f1\"]\n","if \"box_mask_accuracy\" in df.columns:\n","    df.loc[mask, \"Accuracy\"] = df.loc[mask, \"box_mask_accuracy\"]\n","\n","# Delta_mIoU 浼樺厛鐢?Delta_IoU锛涙病鏈夊氨鎸?clean 閲嶆柊绠梊n","if \"Delta_IoU\" in df.columns:\n","    df.loc[mask, \"Delta_mIoU\"] = df.loc[mask, \"Delta_IoU\"]\n","\n","for metric, delta in [(\"F1\", \"Delta_F1\"), (\"Accuracy\", \"Delta_Accuracy\")]:\n","    if delta not in df.columns:\n","        df[delta] = pd.NA\n","\n","# 瀵逛粛涓虹┖鐨?delta锛岀敤鍚?model/dataset 鐨?clean 琛岄噸绠梊n","for (model, dataset), g in df[mask].groupby([\"model\", \"dataset\"], dropna=False):\n","    clean = g[(g[\"perturbation\"] == \"clean\") & (g[\"strength\"].astype(str) == \"none\")]\n","    if clean.empty:\n","        continue\n","    clean_iou = float(clean.iloc[0][\"mIoU\"])\n","    clean_f1 = float(clean.iloc[0][\"F1\"])\n","    clean_acc = float(clean.iloc[0][\"Accuracy\"])\n","    idx = g.index\n","    df.loc[idx, \"Delta_mIoU\"] = pd.to_numeric(df.loc[idx, \"mIoU\"], errors=\"coerce\") - clean_iou\n","    df.loc[idx, \"Delta_F1\"] = pd.to_numeric(df.loc[idx, \"F1\"], errors=\"coerce\") - clean_f1\n","    df.loc[idx, \"Delta_Accuracy\"] = pd.to_numeric(df.loc[idx, \"Accuracy\"], errors=\"coerce\") - clean_acc\n","\n","df.to_csv(path, index=False, encoding=\"utf-8-sig\")\n","\n","cols = [\"model\", \"metric_type\", \"perturbation\", \"strength\", \"mIoU\", \"F1\", \"Accuracy\", \"Delta_mIoU\", \"Delta_F1\", \"Delta_Accuracy\"]\n","print(df.loc[mask, cols].head(30).to_string(index=False))\n","print(\"\\nMissing in Qwen/box rows:\")\n","print(df.loc[mask, cols].isna().sum())\n","print(f\"\\nSaved fixed CSV: {path}\")\n","PY"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5ZNFWkr1NqdC","executionInfo":{"status":"ok","timestamp":1783740412073,"user_tz":-480,"elapsed":265,"user":{"displayName":"demo demo","userId":"05008526215588824690"}},"outputId":"81f40113-4c5e-4dbf-d076-300021cb0092"},"execution_count":37,"outputs":[{"output_type":"stream","name":"stdout","text":["                      model metric_type        perturbation strength     mIoU       F1  Accuracy  Delta_mIoU  Delta_F1  Delta_Accuracy\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask               clean     none 0.597541 0.686660  0.702476    0.000000  0.000000        0.000000\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask          brightness     0.70 0.593351 0.681758  0.704034   -0.004190 -0.004902        0.001558\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask          brightness     0.85 0.597166 0.685365  0.702246   -0.000375 -0.001295       -0.000230\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask          brightness     1.15 0.582496 0.671207  0.689611   -0.015045 -0.015453       -0.012865\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask          brightness     1.30 0.564336 0.651935  0.667644   -0.033205 -0.034726       -0.034831\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask            contrast     0.75 0.593905 0.680702  0.700280   -0.003635 -0.005958       -0.002195\n","Qwen/Qwen2.5-VL-3B-Instruct    box-mask            contrast     0.90 0.578122 0.668141  0.683871   -0.019419 -0.018519       -